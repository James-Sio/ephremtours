{
  "buildCommand": "echo 'Skip build'",
  "outputDirectory": "dist",
  "installCommand": "echo 'Skip install'",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(fleet|tourImages)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
